<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Clock • Dark</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: #121212;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 16px;
        }

        .clock-container {
            background: #000000;
            border-radius: 32px;
            padding: 40px 30px;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.7), 0 0 0 1px #333 inset;
            width: 100%;
            max-width: 500px;
            text-align: center;
            border: 2px solid #2a2a2a;
        }

        .time {
            font-size: 5rem;
            font-weight: 700;
            color: #ff4d4d;
            text-shadow: 0 0 15px #ff0000, 0 0 30px #990000;
            letter-spacing: 5px;
            line-height: 1.2;
            margin-bottom: 20px;
            font-family: 'Courier New', monospace;
        }

        .date {
            font-size: 1.8rem;
            color: #ffffff;
            text-shadow: 0 0 5px #ffffff66;
            font-weight: 400;
            border-top: 1px solid #333;
            padding-top: 20px;
            font-family: 'Segoe UI', sans-serif;
        }
    </style>
</head>
<body>
    <div class="clock-container">
        <div class="time" id="time">00:00:00</div>
        <div class="date" id="date">Mon, Jan 01, 2024</div>
    </div>

    <script>
        (function() {
            const timeElement = document.getElementById('time');
            const dateElement = document.getElementById('date');

            function updateClock() {
                const now = new Date();

                // Форматирование времени: HH:MM:SS (24-часовой формат)
                const hours = now.getHours().toString().padStart(2, '0');
                const minutes = now.getMinutes().toString().padStart(2, '0');
                const seconds = now.getSeconds().toString().padStart(2, '0');
                timeElement.textContent = `${hours}:${minutes}:${seconds}`;

                // Форматирование даты: EEE, MMM dd, yyyy (как в Java)
                const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
                const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
                
                const dayName = days[now.getDay()];
                const monthName = months[now.getMonth()];
                const day = now.getDate().toString().padStart(2, '0');
                const year = now.getFullYear();

                dateElement.textContent = `${dayName}, ${monthName} ${day}, ${year}`;
            }

            // Обновление каждую секунду
            updateClock();
            setInterval(updateClock, 1000);
        })();
    </script>
</body>
</html>
